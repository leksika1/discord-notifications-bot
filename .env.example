# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ID of the Discord channel where notifications are sent
CHANNEL_ID=1234567890123456789

# How often to check for updates (minutes)
CHECK_EVERY_MIN=30
CHECK_TIMEOUT_SEC=25

# Legacy single source (used when CHECK_URLS is empty)
CHECK_URL=https://heroscroll.com/

# Multiple web sources (comma-separated), checked each cycle.
# Bot selects the freshest value and can require agreement via MIN_SOURCE_AGREEMENT.
CHECK_URLS=https://heroscroll.com/
MIN_SOURCE_AGREEMENT=1

# Optional fast lane from Discord watcher:
# - Add source channels where announcements appear first.
# - Bot parses kingdom IDs from messages and notifies instantly.
WATCH_CHANNEL_IDS=
MESSAGE_PATTERNS=
MIN_KINGDOM_ID=1000
MAX_KINGDOM_ID=9999

# Path to state file (can be absolute or relative)
STATE_PATH=data/state.json

# Mention @everyone in notifications
MENTION_EVERYONE=true

# Save fetched pages when parser fails
DEBUG_DUMPS=false
