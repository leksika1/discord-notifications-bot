# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ID of the Discord channel where notifications are sent
CHANNEL_ID=1234567890123456789

# How often to check for updates (minutes)
CHECK_EVERY_MIN=30

# Source URL where "Total Kingdoms: N" is parsed
CHECK_URL=https://www.heroscroll.com/

# Path to state file (can be absolute or relative)
STATE_PATH=data/state.json

# Mention @everyone in notifications
MENTION_EVERYONE=true

# Save fetched pages when parser fails
DEBUG_DUMPS=false
